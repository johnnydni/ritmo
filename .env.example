# ─── Supabase (required for QR Remote-Eingabe) ───────────────────
# 1. Erstelle ein kostenloses Konto auf https://supabase.com
# 2. Neues Projekt anlegen
# 3. Settings → API → URL und anon key hier einfügen

VITE_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=dein_anon_key_hier
